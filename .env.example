NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/st-incident-system
CORS_ORIGIN=http://localhost:3000

# Use independent 64+ character secrets in production.
JWT_SECRET_STAFF=replace-with-64-character-random-staff-secret
JWT_SECRET_STUDENT=replace-with-64-character-random-student-secret
JWT_EXPIRES_IN=24h

RATE_LIMIT_WINDOW_MS=900000
# Production defaults to 150 req/window when unset; development defaults to 3000.
RATE_LIMIT_MAX=150
# Stricter limit for login and password-reset OTP routes (per IP).
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
# OTP validity after forgot-password (default 10 minutes).
PASSWORD_RESET_OTP_EXPIRY_MS=600000
JSON_BODY_LIMIT=10mb
URLENCODED_BODY_LIMIT=10mb
UPLOAD_MAX_FILE_SIZE_BYTES=10485760
UPLOAD_MAX_FILES=10

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Logging (optional)
# LOG_LEVEL=info        # trace | debug | info | warn | error | fatal
# LOG_PRETTY=true       # pretty-print in development (requires: npm install pino-pretty)

# PDF conversion (optional — LibreOffice must be installed)
# LIBREOFFICE_PATH=soffice
# PDF_CONVERSION_TIMEOUT_MS=30000

# School metadata (used in letter generation)
# SCHOOL_NAME=Your School Name
# PRINCIPAL_NAME=Principal

# MongoDB connection tuning (optional)
# MONGO_CONNECT_MAX_ATTEMPTS=5
# MONGO_CONNECT_RETRY_DELAY_MS=3000
# MONGO_MAX_POOL_SIZE=10
# MONGO_MIN_POOL_SIZE=2
# MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
# MONGO_SOCKET_TIMEOUT_MS=45000
# MONGO_HEARTBEAT_FREQUENCY_MS=10000

# HTTP server tuning (optional)
# KEEP_ALIVE_TIMEOUT_MS=65000
# HEADERS_TIMEOUT_MS=66000
