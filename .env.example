# =============================================================================
# Backend Environment Variables — Incident Tracking System
# =============================================================================
# Copy this file to `.env` and fill in your values. Never commit `.env` to git.
# =============================================================================

# ---------- Required ----------

# MongoDB Atlas connection string (SRV format). Supports replica sets.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# JWT secrets — each must be at least 32 characters, cryptographically random.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET_STAFF=<64-char-random-staff-secret>
JWT_SECRET_STUDENT=<64-char-random-student-secret>

# Dedicated file URL encryption/signing secret. Must be different from all JWT secrets.
FILE_URL_SECRET=<64-char-random-file-url-secret>

# ---------- Required in Production ----------

# Comma-separated list of allowed CORS origins (no trailing slash).
# Example: https://your-frontend.vercel.app,https://your-custom-domain.com
CORS_ORIGIN=https://your-frontend-domain.com

# AWS S3 credentials (required when running in production / Render).
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=your-s3-bucket-name
AWS_ACCESS_KEY=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_KEY=<your-aws-secret-key>

# ---------- Server ----------

# Environment: development | production | test
NODE_ENV=development

# Port the Express server listens on.
PORT=5000

# Request body size limits (format: number + unit, e.g. 1mb, 50kb, 10mb)
JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=1mb

# Server socket timeouts (milliseconds)
KEEP_ALIVE_TIMEOUT_MS=120000
HEADERS_TIMEOUT_MS=121000

# Graceful shutdown timeout (milliseconds)
SHUTDOWN_TIMEOUT_MS=5000

# Response compression threshold (bytes). Responses smaller than this are not compressed.
COMPRESSION_THRESHOLD_BYTES=1024

# ---------- JWT & Auth Cookies ----------

# Legacy fallback JWT secret (only used if JWT_SECRET_STAFF / JWT_SECRET_STUDENT not set).
# Not recommended — kept for backward compatibility.
# JWT_SECRET=<64-char-legacy-secret>

# Access token expiry duration (https://github.com/vercel/ms)
JWT_ACCESS_EXPIRES_IN=15m

# Cookie max-age values (milliseconds)
# ACCESS_COOKIE_MAX_AGE_MS=900000
# REFRESH_COOKIE_MAX_AGE_MS=2592000000

# Refresh token time-to-live (days)
# REFRESH_TOKEN_TTL_DAYS=30

# Refresh token reuse grace window (milliseconds) — prevents race-condition errors
# REFRESH_REUSE_GRACE_MS=10000

# Set cookie Secure flag. Override for non-HTTPS environments: false
# COOKIE_SECURE=true

# ---------- Rate Limiting ----------

# Global rate limit (requests per window)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=150

# Auth-specific rate limit (login, register, etc.)
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=10

# ---------- File Upload ----------

# Maximum file size per uploaded file (bytes)
# UPLOAD_MAX_FILE_SIZE_BYTES=10485760
# Maximum number of files per upload request
# UPLOAD_MAX_FILES=10

# ---------- MongoDB Connection Tuning ----------

# Connection retry
# MONGO_CONNECT_MAX_ATTEMPTS=5
# MONGO_CONNECT_RETRY_DELAY_MS=3000

# Connection pool
# MONGO_MAX_POOL_SIZE=10
# MONGO_MIN_POOL_SIZE=2

# Timeouts (milliseconds)
# MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
# MONGO_SOCKET_TIMEOUT_MS=45000

# Heartbeat
# MONGO_HEARTBEAT_FREQUENCY_MS=10000

# ---------- Logging ----------

# Log level: trace | debug | info | warn | error | fatal
# LOG_LEVEL=debug

# Enable pretty-printed Pino logs in development (NODE_ENV must NOT be production)
# LOG_PRETTY=true

# ---------- Document / Spreadsheet Security ----------

# Spreadsheet (XLSX) upload limits
# SPREADSHEET_MAX_ROWS=5000
# SPREADSHEET_MAX_COLUMNS=80

# DOCX file upload limits
# DOCX_MAX_BYTES=10485760
# DOCX_MAX_ENTRIES=300
# DOCX_MAX_XML_ENTRY_BYTES=2097152
# DOCX_MAX_TEXT_CHARS=10000

# ---------- Async Queue Timeouts ----------

# Letter generation queue job timeout (milliseconds)
# LETTER_QUEUE_JOB_TIMEOUT_MS=120000

# Bulk upload queue job timeout (milliseconds)
# BULK_QUEUE_JOB_TIMEOUT_MS=600000

# ---------- Letter Document Templates ----------

# School name and principal name used in generated letter documents.
# SCHOOL_NAME=Your School Name
# PRINCIPAL_NAME=Principal
